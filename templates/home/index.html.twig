                        <a class="btn mx-1" title="linkedin" href="https://www.linkedin.com/in/bee-digital-tech-8a056a201"><i class="fab fa-linkedin"></i></a>
                        <a class="btn mx-1" title="twitter" href="https://mobile.twitter.com/BeeDigital2019"><i class="fab fa-twitter"></i></a>
                    </div>
                </div>
                <div class="col-md-6 mt-3 mb-3 ">
                    <h5>Copyright © Bee Digital 2019 - 2020</h5>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
